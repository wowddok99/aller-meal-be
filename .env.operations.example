# Copy to .env.operations for operations compose.
POSTGRES_DB=aller_meal
POSTGRES_USER=aller_meal
POSTGRES_PASSWORD=local-postgres-password

RABBITMQ_DEFAULT_USER=aller_meal
RABBITMQ_DEFAULT_PASS=local-rabbitmq-password

MINIO_ROOT_USER=aller_meal
MINIO_ROOT_PASSWORD=local-minio-password

AUTH_EMAIL_ENCRYPTION_KEY=bG9jYWwtZW1haWwtZW5jcnlwdGlvbi1rZXktMzJiISE=
AUTH_EMAIL_ENCRYPTION_KEY_VERSION=v1-local
AUTH_EMAIL_FROM=no-reply@allermeal.local
EMAIL_VERIFICATION_BASE_URL=https://localhost:18443/api/v1/auth/email-verifications/confirm?token=
EMAIL_VERIFICATION_TOKEN_TTL=30m
PASSWORD_RESET_BASE_URL=https://localhost:18443/password-reset?token=
AUTH_ACCESS_TOKEN_SIGNING_KEY=bG9jYWwtYWNjZXNzLXRva2VuLXNpZ25pbmcta2V5LTMyYiEh
AUTH_ACCESS_TOKEN_TTL=15m
AUTH_REFRESH_TOKEN_TTL=14d
AUTH_ALLOWED_ORIGINS=https://localhost:18443
ALLER_MEAL_AUTH_COOKIE_SECURE=true
ALLER_MEAL_AUTH_COOKIE_SAME_SITE=Lax
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=

RAW_PAYLOAD_RETENTION_PERIOD=P90D
RAW_PAYLOAD_RETENTION_BATCH_SIZE=100
OPERATION_LOG_RETENTION_PERIOD=P365D
OPERATION_LOG_RETENTION_BATCH_SIZE=100
DATA_RETENTION_CLEANUP_SCHEDULER_ENABLED=true
DATA_RETENTION_CLEANUP_SCHEDULER_FIXED_DELAY=PT24H

# Use a real HTTPS domain outside local smoke checks.
ALLER_MEAL_DOMAIN=localhost
CADDY_HTTP_PORT=18080
CADDY_HTTPS_PORT=18443
